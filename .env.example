# ══════════════════════════════════════════════════════════════════
#  Polymarket BTC 15-Min Trading Bot — Environment Variables
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to version control
# ══════════════════════════════════════════════════════════════════

# ── Polymarket Wallet ─────────────────────────────────────────────
# POLYMARKET_PK       Private key of the EOA that SIGNS orders.
#                     If you use MetaMask: export the private key of the
#                     MetaMask account you connected to Polymarket.
# POLYMARKET_FUNDER   Address that HOLDS the USDC (your "Polymarket address",
#                     visible on Polymarket → Deposit). For MetaMask users
#                     this is the proxy / Gnosis Safe Polymarket created
#                     for you, NOT your MetaMask address.
# POLYMARKET_SIG_TYPE 0 = EOA  (you trade from MetaMask address directly,
#                                 USDC sits on the EOA — uncommon)
#                     1 = POLY_PROXY        (older MetaMask / browser-wallet accounts)
#                     2 = POLY_GNOSIS_SAFE  (modern MetaMask / Magic / email accounts)
#                     If unsure, run:  python scripts/regen_polymarket_keys.py
POLYMARKET_PK=0x...
POLYMARKET_FUNDER=0x...
POLYMARKET_SIG_TYPE=2

# ── Polymarket CLOB API Keys ──────────────────────────────────────
# Generate with:  python scripts/regen_polymarket_keys.py
POLYMARKET_API_KEY=...
POLYMARKET_API_SECRET=...
POLYMARKET_PASSPHRASE=...

# ── Ethereum RPC (required for Chainlink settlement tracking) ─────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# ── Gamma API (optional — defaults to public endpoint) ───────────
# GAMMA_API_URL=https://gamma-api.polymarket.com

# ── Order sizing ─────────────────────────────────────────────────
MARKET_BUY_USD=1.00                  # USD per market BUY order

# ── Trading risk parameters ──────────────────────────────────────
# ENABLE_STOP_LOSS
#   false (default) → no early stop-loss; positions ride to TP or to
#                     Polymarket settlement (binary token → 0 or 1).
#                     ⚠️  A losing trade then loses ~100% of its stake.
#   true            → stop-loss enforced at STOP_LOSS_PCT below entry.
# STOP_LOSS_PCT   (only used when ENABLE_STOP_LOSS=true)
#                   SL = entry - STOP_LOSS_PCT * entry
# TAKE_PROFIT_PCT fraction of remaining upside taken per trade.
#                   TP = entry + TAKE_PROFIT_PCT * (1 - entry)
ENABLE_STOP_LOSS=false
STOP_LOSS_PCT=0.50
TAKE_PROFIT_PCT=0.40

# Refuse entries with price outside this band — extreme prices
# (0.95 YES, 0.05 NO) have negative expected value.
MIN_ENTRY_PRICE=0.25
MAX_ENTRY_PRICE=0.75

# Skip trades when (ask - bid) / mid > MAX_SPREAD_PCT.
MAX_SPREAD_PCT=0.05

# Re-entry cooldown and trade-window (seconds inside each 15-min market).
ENTRY_COOLDOWN_SEC=90
TRADE_WINDOW_SEC_START=300            # minute 5
TRADE_WINDOW_SEC_END=780              # minute 13

# Refuse new entries this many seconds before market close.
LATE_ENTRY_CUTOFF_SEC=120

# Cooldown after a pre-trade filter rejection — prevents busy-looping
# the decision banner at full tick rate when price is out of band.
FILTER_REJECT_COOLDOWN_SEC=15

# Per-market constraints. LOCK_MARKET_DIRECTION blocks the "win then
# fade" pattern where the bot wins LONG then immediately bets SHORT
# in the same market and loses. MAX_TRADES_PER_MARKET caps re-entries
# (set to 1 to fire exactly one bet per market).
# MAX_CHASE_DELTA refuses to chase a token whose price has run away.
LOCK_MARKET_DIRECTION=true
MAX_TRADES_PER_MARKET=1
MAX_CHASE_DELTA=0.12

# Minimum probability gap (in fractions) between ML p(UP) and the
# Polymarket implied price before betting. 0.10 = require 10pp edge.
# Only used while the ML model is active (after MIN_SAMPLES outcomes).
MIN_ML_EDGE=0.10

# ── Redis (optional — enables live mode-switching without restart) 
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
